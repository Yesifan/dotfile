# Stable global command approval rules.
# These rules apply only when Codex requests to run commands outside the sandbox.

prefix_rule(
    pattern = [
        "git",
        [
            "status",
            "diff",
            "log",
            "show",
            "branch",
            "rev-parse",
            "remote",
        ],
    ],
    decision = "allow",
    justification = "Read-only Git inspection commands.",
    match = [
        "git status",
        "git diff",
        "git log --oneline -10",
        "git show HEAD",
        "git branch --show-current",
    ],
    not_match = [
        "git push",
        "git reset --hard",
    ],
)

prefix_rule(
    pattern = ["rg"],
    decision = "allow",
    justification = "Repository text search.",
)

prefix_rule(
    pattern = ["fd"],
    decision = "allow",
    justification = "Repository file search.",
)

prefix_rule(
    pattern = [
        "pnpm",
        [
            "lint",
            "test",
            "check",
            "typecheck",
            "run",
        ],
    ],
    decision = "allow",
    justification = "Standard pnpm checks and project scripts in trusted workspaces.",
    match = [
        "pnpm test",
        "pnpm lint",
        "pnpm check",
        "pnpm typecheck",
        "pnpm run dev",
        "pnpm run build",
    ],
    not_match = [
        "pnpm install",
        "pnpm add vite",
    ],
)

prefix_rule(
    pattern = [
        "pnpm",
        "exec",
        [
            "eslint",
            "prettier",
        ],
    ],
    decision = "allow",
    justification = "Run local eslint/prettier binaries from trusted workspaces.",
    match = [
        "pnpm exec eslint .",
        "pnpm exec prettier --check .",
        "pnpm exec prettier --write src",
    ],
    not_match = [
        "pnpm exec vite",
        "pnpm dlx eslint .",
    ],
)

prefix_rule(
    pattern = [
        "pnpm",
        "exec",
        "--",
        [
            "eslint",
            "prettier",
        ],
    ],
    decision = "allow",
    justification = "Run local eslint/prettier binaries from trusted workspaces.",
    match = [
        "pnpm exec -- eslint .",
        "pnpm exec -- prettier --check .",
    ],
)

prefix_rule(
    pattern = [
        "npm",
        "exec",
        [
            "eslint",
            "prettier",
        ],
    ],
    decision = "allow",
    justification = "Run local eslint/prettier binaries from trusted workspaces.",
    match = [
        "npm exec eslint .",
        "npm exec prettier --check .",
    ],
    not_match = [
        "npm exec vite",
    ],
)

prefix_rule(
    pattern = [
        "npm",
        "exec",
        "--",
        [
            "eslint",
            "prettier",
        ],
    ],
    decision = "allow",
    justification = "Run local eslint/prettier binaries from trusted workspaces.",
    match = [
        "npm exec -- eslint .",
        "npm exec -- prettier --check .",
    ],
)

prefix_rule(
    pattern = [
        "npx",
        [
            "eslint",
            "prettier",
        ],
    ],
    decision = "allow",
    justification = "Run eslint/prettier through npx in trusted workspaces.",
    match = [
        "npx eslint .",
        "npx prettier --check .",
    ],
    not_match = [
        "npx vite",
    ],
)

prefix_rule(
    pattern = [
        "pnpm",
        "dlx",
        [
            "shadcn",
            "shadcn@latest",
            "shadcn-svelte",
            "shadcn-svelte@latest",
        ],
        [
            "add",
            "init",
        ],
    ],
    decision = "allow",
    justification = "Run shadcn component scaffolding commands in trusted workspaces.",
    match = [
        "pnpm dlx shadcn@latest add button",
        "pnpm dlx shadcn-svelte@latest add button",
        "pnpm dlx shadcn-svelte@latest init",
    ],
    not_match = [
        "pnpm dlx vite",
    ],
)

prefix_rule(
    pattern = [
        "npx",
        [
            "shadcn",
            "shadcn@latest",
            "shadcn-svelte",
            "shadcn-svelte@latest",
        ],
        [
            "add",
            "init",
        ],
    ],
    decision = "allow",
    justification = "Run shadcn component scaffolding commands in trusted workspaces.",
    match = [
        "npx shadcn@latest add button",
        "npx shadcn-svelte@latest add button",
        "npx shadcn-svelte@latest init",
    ],
    not_match = [
        "npx vite",
    ],
)

prefix_rule(
    pattern = [
        [
            "shadcn",
            "shadcn-svelte",
        ],
        [
            "add",
            "init",
        ],
    ],
    decision = "allow",
    justification = "Run installed shadcn component scaffolding commands in trusted workspaces.",
    match = [
        "shadcn add button",
        "shadcn-svelte add button",
        "shadcn-svelte init",
    ],
)

prefix_rule(
    pattern = [
        "git",
        [
            "add",
            "commit",
            "push",
            "reset",
            "clean",
            "rebase",
            "checkout",
            "switch",
            "restore",
            "merge",
            "pull",
        ],
    ],
    decision = "prompt",
    justification = "Git command may modify files, history, or remote state.",
)

prefix_rule(
    pattern = [
        "pnpm",
        [
            "add",
            "install",
            "remove",
            "update",
            "approve-builds",
        ],
    ],
    decision = "prompt",
    justification = "pnpm command may install dependencies or execute project scripts.",
)

prefix_rule(
    pattern = [
        "npm",
        [
            "install",
            "i",
            "update",
            "run",
        ],
    ],
    decision = "prompt",
    justification = "npm command may install dependencies or execute project scripts.",
)

prefix_rule(
    pattern = ["curl"],
    decision = "prompt",
    justification = "curl can access arbitrary network resources or download executable content.",
)

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Run privileged commands manually after reviewing them.",
)

prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Never recursively delete the filesystem root.",
)
