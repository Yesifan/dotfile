{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "small_model": "opencode/deepseek-v4-flash-free",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    },
    "build": {
      "variant": "max"
    },
    "general": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "**/*.pem": "deny",
      "**/*.key": "deny"
    },
    "edit": {
      "*": "allow",
      "**/*.pem": "deny",
      "**/*.key": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "skill": "allow",
    "github_*": "allow",
    "playwright_*": "allow",
    "bash": {
      "*": "allow",
      "npm run lint": "allow",
      "npm run lint *": "allow",
      "npm install": "allow",
      "npm ci": "allow",
      "pnpm install": "allow",
      "pnpm ci": "allow",
      "pnpm run lint": "allow",
      "pnpm run lint *": "allow",
      "yarn install": "allow",
      "yarn run lint": "allow",
      "yarn run lint *": "allow",
      "cargo build *": "allow",
      "cargo check *": "allow",
      "go build *": "allow",
      "go vet *": "allow",
      "terraform plan *": "allow",
      "tofu plan *": "allow",
      "terraform fmt *": "allow",
      "tofu fmt *": "allow",
      "docker ps": "allow",
      "docker images": "allow",
      "docker pull *": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "rm *": "ask",
      "node *": "ask",
      "bun *": "ask",
      "deno *": "ask",
      "python *": "ask",
      "python3 *": "ask",
      "npx *": "ask",
      "tsx *": "ask",
      "sudo *": "ask",
      "doas *": "ask",
      "eval *": "ask",
      "source *": "ask",
      "perl *": "ask",
      "ruby *": "ask",
      "php *": "ask",
      "make *": "ask",
      "cargo run *": "ask",
      "cargo test *": "ask",
      "go run *": "ask",
      "dotnet run *": "ask",
      "dotnet test *": "ask",
      "docker run *": "ask",
      "docker compose *": "ask",
      "docker build *": "ask",
      "docker exec *": "ask",
      "docker push *": "ask",
      "kubectl exec *": "ask",
      "kubectl run *": "ask",
      "kubectl apply *": "ask",
      "kubectl delete *": "ask",
      "helm install *": "ask",
      "helm upgrade *": "ask",
      "terraform apply *": "ask",
      "terraform destroy *": "ask",
      "tofu apply *": "ask",
      "tofu destroy *": "ask",
      "pulumi up *": "ask",
      "pulumi destroy *": "ask",
      "turbo run *": "ask",
      "nx run *": "ask",
      "systemctl start *": "ask",
      "systemctl stop *": "ask",
      "systemctl restart *": "ask",
      "service * start": "ask",
      "service * restart": "ask",
      "ssh *": "ask",
      "rsync *": "ask",
      "kill *": "ask",
      "rm -rf /*": "deny",
      "rm -rf /": "deny",
      "rm -rf ~": "deny",
      "rm -rf $HOME": "deny",
      "rm -rf /home/*": "deny",
      "rm -rf /etc/*": "deny",
      "mkfs*": "deny",
      "dd if=* of=/dev/*": "deny",
      "dd if=* of=/*": "deny",
      "chmod -R 777 /*": "deny",
      "chown -R * /*": "deny",
      ":(){": "deny",
      "shutdown *": "deny",
      "reboot": "deny",
      "poweroff": "deny",
      "curl * | sh": "deny",
      "curl * | bash": "deny",
      "wget * | sh": "deny",
      "wget * | bash": "deny"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      "~/.agents/skills/": "allow"
    },
    "doom_loop": "ask"
  },
  "formatter": true,
  "lsp": true,
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 10000
  },
  "tool_output": {
    "max_lines": 2000,
    "max_bytes": 51200
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
